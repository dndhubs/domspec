{
  "extends": "@dndhub/config/tsconfig/node.json",
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "sourceMap": false,
    "rootDir": "./src",
    "outDir": "./dist",
    "isolatedModules": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dev", "ref", "node_modules", "dist"]
}